{
  "name": "@pcircle/footprint",
  "version": "1.5.0",
  "description": "MCP server that automatically captures and encrypts AI conversations as verifiable records with Git timestamps and end-to-end encryption.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "llm",
    "audit",
    "audit-trail",
    "encryption",
    "footprint",
    "claude",
    "chatgpt",
    "compliance",
    "timestamp"
  ],
  "author": "PCIRCLE, LLC",
  "license": "MIT",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "bin": {
    "footprint": "./dist/src/cli/index.js"
  },
  "files": [
    "dist/src",
    "!dist/src/test-helpers*",
    "dist/ui",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/PCIRCLE-AI/footprint-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/PCIRCLE-AI/footprint-mcp/issues"
  },
  "homepage": "https://footprint.memesh.ai",
  "scripts": {
    "build": "pnpm build:ui && tsc",
    "build:ui": "mkdir -p dist/ui && pnpm build:ui:dashboard && pnpm build:ui:detail && pnpm build:ui:export",
    "build:ui:dashboard": "cross-env INPUT=ui/dashboard.html vite build --outDir dist/ui-tmp && cp dist/ui-tmp/ui/dashboard.html dist/ui/dashboard.html",
    "build:ui:detail": "cross-env INPUT=ui/detail.html vite build --outDir dist/ui-tmp && cp dist/ui-tmp/ui/detail.html dist/ui/detail.html",
    "build:ui:export": "cross-env INPUT=ui/export.html vite build --outDir dist/ui-tmp && cp dist/ui-tmp/ui/export.html dist/ui/export.html",
    "dev": "concurrently 'pnpm build:ui --watch' 'tsc --watch'",
    "test": "vitest",
    "test:run": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm test:run"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@noble/ciphers": "^2.1.1",
    "@noble/hashes": "^2.0.1",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "isomorphic-git": "^1.37.1",
    "jszip": "^3.10.1",
    "ora": "^9.3.0",
    "prompts": "^2.4.2",
    "zod": "^4.3.6",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^22.19.11",
    "@types/prompts": "^2.4.9",
    "@types/zxcvbn": "^4.4.5",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "undici": ">=6.23.0",
      "ajv": ">=8.18.0",
      "qs": ">=6.14.2"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
